// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /accounts
// Document ID: accountId
// Fields:
//   - name: string (required)
//   - balance: number (required)
//   - currency: string (required)
//   - type: string (required)
//   - lastUpdated: string (optional)
//
// Collection: /accounts/{accountId}/transactions
// Document ID: transactionId
// Fields:
//   - accountId: string (required)
//   - amount: number (required)
//   - type: string (required, enum: ['credit', 'debit'])
//   - timestamp: string (required)
//   - description: string (optional)
//   - category: string (optional)
//
// Collection: /forecasts
// Document ID: forecastId
// Fields:
//   - date: string (required)
//   - value: number (required)
//   - confidence: number (required)
//   - swarmMetadata: string (optional)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "nashetaliaiexpert@gmail.com" && request.auth.token.email_verified == true);
    }
    
    function isValidAccount(data) {
      return data.keys().hasAll(['name', 'balance', 'currency', 'type']) &&
             data.name is string && data.name.size() < 100 &&
             data.balance is number &&
             data.currency is string && data.currency.size() == 3 &&
             data.type is string;
    }
    
    function isValidTransaction(data) {
      return data.keys().hasAll(['accountId', 'amount', 'type', 'timestamp']) &&
             data.accountId is string &&
             data.amount is number &&
             data.type in ['credit', 'debit'] &&
             data.timestamp is string;
    }
    
    function isValidForecast(data) {
      return data.keys().hasAll(['date', 'value', 'confidence']) &&
             data.date is string &&
             data.value is number &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 1;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /accounts/{accountId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAccount(request.resource.data);
      allow delete: if isAdmin();
      
      match /transactions/{transactionId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin() && isValidTransaction(request.resource.data);
        allow update, delete: if isAdmin();
      }
    }
    
    match /forecasts/{forecastId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidForecast(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
